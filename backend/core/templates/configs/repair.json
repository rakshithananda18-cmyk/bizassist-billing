{
  "key": "repair",
  "label": "Repair / Service Center",
  "terminology": {
    "customer": "Customer",
    "product": "Part / Service",
    "bill": "Service Invoice",
    "supplier": "Parts Supplier"
  },
  "billing": {
    "default_invoice_type": "B2C",
    "tax_inclusive_default": false,
    "entry_mode": "search",
