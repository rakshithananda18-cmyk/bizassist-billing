  "inventory": {
    "track_batch": false,
    "track_expiry": false,
    "track_serial": true,
    "loose_qty": false,
    "default_uoms": ["Nos", "Job"],
    "reorder_default": 5
  },
  "product_fields": [
    {"field": "name", "required": true},
    {"field": "hsn_sac", "label": "HSN/SAC"},
    {"field": "selling_price", "label": "Charge", "required": true},
    {"attr": "service_type", "label": "Type", "type": "select", "options": ["Part", "Labour", "Diagnostic"]}
  ],
  "invoice_layout": "a4_service",
  "workflows": ["job_cards"],
  "ai_pack": "available"
}
