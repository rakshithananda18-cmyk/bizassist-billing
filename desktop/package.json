{
  "name": "bizassist-desktop",
  "productName": "BizAssist",
  "version": "1.1.3",
  "description": "BizAssist — Offline-first Billing & POS",
  "main": "src/main.js",
  "author": "BizAssist",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "prepare-renderer": "node scripts/prepare-renderer.js",
    "dist:win": "electron-builder --win --publish never",
    "dist:mac": "electron-builder --mac --publish never",
    "release": "electron-builder --publish always"
  },
  "devDependencies": {
    "electron": "^31.3.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "electron-updater": "^6.3.0",
    "electron-log": "^5.1.7"
  },
  "build": {
    "appId": "com.bizassist.desktop",
    "productName": "BizAssist",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      { "from": "resources/backend", "to": "backend" },
      { "from": "resources/renderer", "to": "renderer" }
    ],
    "asar": true,
    "publish": [
      {
        "provider": "github",
        "owner": "rakshithananda18-cmyk",
        "repo": "bizassist-billing",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "build/icon.png",
      "artifactName": "BizAssist-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "perMachine": false,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] },
        { "target": "zip", "arch": ["x64", "arm64"] }
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.business",
      "artifactName": "BizAssist-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "build/icon.png",
      "category": "Office"
    }
  }
}
