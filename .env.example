# BizAssist environment variables
# Copy this file to backend\.env and fill in your values.
# On Hugging Face, set these under Settings → Variables and secrets
# (keys/passwords as SECRETS, the rest as VARIABLES).

# ════════════════════════════════════════════════════════════════
# REQUIRED
# ════════════════════════════════════════════════════════════════

# Groq API key — powers all LLM tiers + the LLM router.
# Get a free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Auth token signing secret — use a long random string in production.
JWT_SECRET=change-this-to-a-long-random-secret

# Initial admin account password (seeded on first run).
# CHANGE THIS — the fallback default is insecure.
ADMIN_SEED_PASSWORD=change-me-to-a-strong-password

# ════════════════════════════════════════════════════════════════
# ROUTING & AGENT  (recommended values shown)
# ════════════════════════════════════════════════════════════════

# Router mode at startup: off (legacy) | shadow | on (new LLM router).
# Admin can flip live, but that override resets to this value on restart.
LLM_ROUTER=off
# Below this confidence the LLM router defers to the legacy router.
LLM_ROUTER_CONF_FLOOR=0.6
# AI_COMPLEX engine: loop (adaptive tool-calling, cheaper) | pipeline (fixed fan-out).
AGENT_MODE=loop
# Embedding shadow router: off | shadow | on. shadow is free (local model).
INTENT_ROUTER=shadow
# Inject the deterministic business snapshot into AI_SIMPLE answers.
SNAPSHOT_CONTEXT=true
# Bounds for the agent loop.
AGENT_MAX_TOOL_ROUNDS=5
MAX_TOOL_CHARS=4000

# ════════════════════════════════════════════════════════════════
# INFRASTRUCTURE
# ════════════════════════════════════════════════════════════════

# Database (DATABASE_URL). The app + alembic both read this one variable.
#   - Local dev (Docker Postgres):  postgresql://postgres:devpass@localhost:5432/bizassist
#   - Hugging Face (Supabase):      set as a SPACE SECRET, not here
#   - Zero-setup fallback:          sqlite:///./bizassist.db
DATABASE_URL=postgresql://postgres:devpass@localhost:5432/bizassist

# Keep at 1 — caches, rate-limit windows, and the scheduler are in-memory.
WEB_CONCURRENCY=1

# ── Admin Console (organiser-only) ──────────────────────────────
# Fail-closed gate for ALL /admin/* endpoints. Default (unset/0) = the admin
# API does not exist (404) — the desktop/PyInstaller build must NEVER set this.
# Set to 1 ONLY on the organiser's cloud backend (the HF Dockerfile sets it).
# ADMIN_API_ENABLED=1

# Subscription enforcement (Phase B.5). 0 (default) = plan hooks are dormant:
# admins can grant/revoke plans in the console but nothing is blocked yet.
# 1 = /ask* and hybrid-sync activation require an active "pro" plan.
# SUBSCRIPTION_ENFORCED=1

# Logging level: INFO normally, DEBUG to trace routing. (Don't set LOG_FILE on HF.)
LOG_LEVEL=INFO

# CORS — comma-separated. Leave UNSET to use the built-in defaults
# (localhost dev ports + the Vercel + HF origins). Set only if your URL differs.
# ALLOWED_ORIGINS=https://your-frontend.vercel.app

# ════════════════════════════════════════════════════════════════
# MODEL OVERRIDES  (optional — code defaults already use these)
# ════════════════════════════════════════════════════════════════
# Groq deprecated qwen3-32b, llama-3.3-70b and llama-3.1-8b (2026). Current
# non-deprecated models on GroqCloud: llama-4-scout (fast + vision) and
# gpt-oss-120b (reasoning). If Groq retires one, just change the value here.
# GROQ_MODEL_ROUTER=meta-llama/llama-4-scout-17b-16e-instruct
# GROQ_MODEL_SIMPLE=meta-llama/llama-4-scout-17b-16e-instruct
# GROQ_MODEL_COMPLEX=openai/gpt-oss-120b
# GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct   # bill-photo OCR

# ════════════════════════════════════════════════════════════════
# EMAIL (optional — only needed to SEND real payment reminders)
# Gmail: use an App Password, not your login password.
# https://support.google.com/accounts/answer/185833
# ════════════════════════════════════════════════════════════════
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_FROM=your_email@gmail.com

# ════════════════════════════════════════════════════════════════
# OPTIONAL AI KEYS
# ════════════════════════════════════════════════════════════════
# Claude — fallback for PDF invoice parsing (optional).
# CLAUDE_API_KEY=your_anthropic_api_key_here
# Legacy / unused in the Groq path:
# GEMINI_API_KEY=your_gemini_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

# ════════════════════════════════════════════════════════════════
# WhatsApp (Twilio) — not wired up yet; reserved for later.
# ════════════════════════════════════════════════════════════════
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
