# BizAssist Environment Variables
# Copy this file to backend\.env and fill in your values

# ── AI API Keys ────────────────────────────────
# Get your free API key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Claude
CLAUDE_API_KEY=your_anthropic_api_key_here

# ── Database ───────────────────────────────────
# Defaults to SQLite if not set
DATABASE_URL=sqlite:///./bizassist.db

# ── Auth ───────────────────────────────────────
JWT_SECRET=change-this-to-a-random-secret-in-production

# ── Routing & agent (all optional; safe defaults shown) ─────────
# Router mode at startup: off (legacy) | shadow | on (new LLM router).
# Admin can flip live, but that override resets to this value on restart.
LLM_ROUTER=off
# Below this confidence the LLM router defers to the legacy router.
LLM_ROUTER_CONF_FLOOR=0.6
# AI_COMPLEX engine: pipeline (fixed fan-out) | loop (adaptive tool-calling).
AGENT_MODE=pipeline
# Embedding shadow router: off | shadow | on.
INTENT_ROUTER=off

# ── Email Notifications (SMTP) ─────────────────
# Gmail example: use an App Password, not your main password
# https://support.google.com/accounts/answer/185833
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_FROM=your_email@gmail.com

# ── WhatsApp Notifications (Twilio) ────────────
# Not required yet — add later when upgrading to WhatsApp alerts
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
