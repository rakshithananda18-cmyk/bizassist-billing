# BizAssist Environment Variables
# Copy this file to backend\.env and fill in your values

# ── AI API Keys ────────────────────────────────
# Get your free API key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Claude
CLAUDE_API_KEY=your_anthropic_api_key_here

# ── Database ───────────────────────────────────
# Defaults to SQLite if not set
DATABASE_URL=sqlite:///./bizassist.db

# ── Auth ───────────────────────────────────────
JWT_SECRET=change-this-to-a-random-secret-in-production

# ── Email Notifications (SMTP) ─────────────────
# Gmail example: use an App Password, not your main password
# https://support.google.com/accounts/answer/185833
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_FROM=your_email@gmail.com

# ── WhatsApp Notifications (Twilio) ────────────
# Not required yet — add later when upgrading to WhatsApp alerts
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
